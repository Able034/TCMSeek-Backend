<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tcmseek.webmanage.mapper.PhenotypeTargetRelMapper">
    
    <resultMap type="PhenotypeTargetRel" id="PhenotypeTargetRelResult">
        <result property="id"    column="id"    />
        <result property="phenotypeId"    column="phenotype_id"    />
        <result property="tcmTarId"    column="tcm_tar_id"    />
        <result property="createdAt"    column="created_at"    />
    </resultMap>

    <sql id="selectPhenotypeTargetRelVo">
        select id, phenotype_id, tcm_tar_id, created_at from phenotype_target_rel
    </sql>

    <select id="selectPhenotypeTargetRelList" parameterType="PhenotypeTargetRel" resultMap="PhenotypeTargetRelResult">
        <include refid="selectPhenotypeTargetRelVo"/>
        <where>  
            <if test="phenotypeId != null  and phenotypeId != ''"> and phenotype_id = #{phenotypeId}</if>
            <if test="tcmTarId != null  and tcmTarId != ''"> and tcm_tar_id = #{tcmTarId}</if>
        </where>
    </select>
    
    <select id="selectPhenotypeTargetRelById" parameterType="Long" resultMap="PhenotypeTargetRelResult">
        <include refid="selectPhenotypeTargetRelVo"/>
        where id = #{id}
    </select>

    <insert id="insertPhenotypeTargetRel" parameterType="PhenotypeTargetRel" useGeneratedKeys="true" keyProperty="id">
        insert into phenotype_target_rel
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="phenotypeId != null and phenotypeId != ''">phenotype_id,</if>
            <if test="tcmTarId != null and tcmTarId != ''">tcm_tar_id,</if>
            <if test="createdAt != null">created_at,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="phenotypeId != null and phenotypeId != ''">#{phenotypeId},</if>
            <if test="tcmTarId != null and tcmTarId != ''">#{tcmTarId},</if>
            <if test="createdAt != null">#{createdAt},</if>
         </trim>
    </insert>

    <update id="updatePhenotypeTargetRel" parameterType="PhenotypeTargetRel">
        update phenotype_target_rel
        <trim prefix="SET" suffixOverrides=",">
            <if test="phenotypeId != null and phenotypeId != ''">phenotype_id = #{phenotypeId},</if>
            <if test="tcmTarId != null and tcmTarId != ''">tcm_tar_id = #{tcmTarId},</if>
            <if test="createdAt != null">created_at = #{createdAt},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deletePhenotypeTargetRelById" parameterType="Long">
        delete from phenotype_target_rel where id = #{id}
    </delete>

    <delete id="deletePhenotypeTargetRelByIds" parameterType="String">
        delete from phenotype_target_rel where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>