<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tcmseek.webmanage.mapper.PathwayTargetRelMapper">
    
    <resultMap type="PathwayTargetRel" id="PathwayTargetRelResult">
        <result property="id"    column="id"    />
        <result property="pathwayId"    column="pathway_id"    />
        <result property="tcmTarId"    column="tcm_tar_id"    />
        <result property="createdAt"    column="created_at"    />
    </resultMap>

    <sql id="selectPathwayTargetRelVo">
        select id, pathway_id, tcm_tar_id, created_at from pathway_target_rel
    </sql>

    <select id="selectPathwayTargetRelList" parameterType="PathwayTargetRel" resultMap="PathwayTargetRelResult">
        <include refid="selectPathwayTargetRelVo"/>
        <where>  
            <if test="pathwayId != null  and pathwayId != ''"> and pathway_id = #{pathwayId}</if>
            <if test="tcmTarId != null  and tcmTarId != ''"> and tcm_tar_id = #{tcmTarId}</if>
        </where>
    </select>
    
    <select id="selectPathwayTargetRelById" parameterType="Long" resultMap="PathwayTargetRelResult">
        <include refid="selectPathwayTargetRelVo"/>
        where id = #{id}
    </select>

    <insert id="insertPathwayTargetRel" parameterType="PathwayTargetRel" useGeneratedKeys="true" keyProperty="id">
        insert into pathway_target_rel
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="pathwayId != null and pathwayId != ''">pathway_id,</if>
            <if test="tcmTarId != null and tcmTarId != ''">tcm_tar_id,</if>
            <if test="createdAt != null">created_at,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="pathwayId != null and pathwayId != ''">#{pathwayId},</if>
            <if test="tcmTarId != null and tcmTarId != ''">#{tcmTarId},</if>
            <if test="createdAt != null">#{createdAt},</if>
         </trim>
    </insert>

    <update id="updatePathwayTargetRel" parameterType="PathwayTargetRel">
        update pathway_target_rel
        <trim prefix="SET" suffixOverrides=",">
            <if test="pathwayId != null and pathwayId != ''">pathway_id = #{pathwayId},</if>
            <if test="tcmTarId != null and tcmTarId != ''">tcm_tar_id = #{tcmTarId},</if>
            <if test="createdAt != null">created_at = #{createdAt},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deletePathwayTargetRelById" parameterType="Long">
        delete from pathway_target_rel where id = #{id}
    </delete>

    <delete id="deletePathwayTargetRelByIds" parameterType="String">
        delete from pathway_target_rel where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>