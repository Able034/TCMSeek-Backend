<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tcmseek.webmanage.mapper.HerbCompoundRelMapper">
    
    <resultMap type="HerbCompoundRel" id="HerbCompoundRelResult">
        <result property="id"    column="id"    />
        <result property="tcmHerbId"    column="tcm_herb_id"    />
        <result property="inchikey"    column="inchikey"    />
        <result property="annotation"    column="annotation"    />
        <result property="source"    column="source"    />
        <result property="createdAt"    column="created_at"    />
    </resultMap>

    <sql id="selectHerbCompoundRelVo">
        select id, tcm_herb_id, inchikey, annotation, source, created_at from herb_compound_rel
    </sql>

    <select id="selectHerbCompoundRelList" parameterType="HerbCompoundRel" resultMap="HerbCompoundRelResult">
        <include refid="selectHerbCompoundRelVo"/>
        <where>  
            <if test="tcmHerbId != null  and tcmHerbId != ''"> and tcm_herb_id = #{tcmHerbId}</if>
            <if test="inchikey != null  and inchikey != ''"> and inchikey = #{inchikey}</if>
        </where>
    </select>
    
    <select id="selectHerbCompoundRelById" parameterType="Long" resultMap="HerbCompoundRelResult">
        <include refid="selectHerbCompoundRelVo"/>
        where id = #{id}
    </select>

    <insert id="insertHerbCompoundRel" parameterType="HerbCompoundRel" useGeneratedKeys="true" keyProperty="id">
        insert into herb_compound_rel
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="tcmHerbId != null and tcmHerbId != ''">tcm_herb_id,</if>
            <if test="inchikey != null and inchikey != ''">inchikey,</if>
            <if test="annotation != null">annotation,</if>
            <if test="source != null">source,</if>
            <if test="createdAt != null">created_at,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="tcmHerbId != null and tcmHerbId != ''">#{tcmHerbId},</if>
            <if test="inchikey != null and inchikey != ''">#{inchikey},</if>
            <if test="annotation != null">#{annotation},</if>
            <if test="source != null">#{source},</if>
            <if test="createdAt != null">#{createdAt},</if>
         </trim>
    </insert>

    <update id="updateHerbCompoundRel" parameterType="HerbCompoundRel">
        update herb_compound_rel
        <trim prefix="SET" suffixOverrides=",">
            <if test="tcmHerbId != null and tcmHerbId != ''">tcm_herb_id = #{tcmHerbId},</if>
            <if test="inchikey != null and inchikey != ''">inchikey = #{inchikey},</if>
            <if test="annotation != null">annotation = #{annotation},</if>
            <if test="source != null">source = #{source},</if>
            <if test="createdAt != null">created_at = #{createdAt},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteHerbCompoundRelById" parameterType="Long">
        delete from herb_compound_rel where id = #{id}
    </delete>

    <delete id="deleteHerbCompoundRelByIds" parameterType="String">
        delete from herb_compound_rel where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>