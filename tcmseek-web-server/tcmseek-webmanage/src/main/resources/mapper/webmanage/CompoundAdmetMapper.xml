    <delete id="deleteCompoundAdmetById" parameterType="Long">
        delete from compound_admet where id = #{id}
    </delete>

    <delete id="deleteCompoundAdmetByIds" parameterType="String">
        delete from compound_admet where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="selectByInchikeys" parameterType="java.util.List" resultMap="CompoundAdmetResult">
        <include refid="selectCompoundAdmetVo"/>
        where inchikey in
        <foreach collection="inchikeys" item="inchikey" open="(" separator="," close=")">
            #{inchikey}
        </foreach>
    </select>

    <insert id="batchInsertCompoundAdmet" parameterType="java.util.List">
        insert into compound_admet
        (inchikey, ames, bbbp, bioavailability, caco2, carcinogens, clearance_microsome, clintox,
         cyp1a2_inhibition, cyp2c19_inhibition, cyp2c9_inhibition, cyp2c9_substrate, cyp2d6_inhibition,
         cyp2d6_substrate, cyp3a4_inhibition, cyp3a4_substrate, dili, freesolv, herg_blockers, herg_karim,
         hia, ld50, lipophilicity, pampa, pgp, ppbr, skin, solubility, created_at, updated_at)
        values
        <foreach collection="list" item="item" separator=",">
            (#{item.inchikey}, #{item.ames}, #{item.bbbp}, #{item.bioavailability}, #{item.caco2},
             #{item.carcinogens}, #{item.clearanceMicrosome}, #{item.clintox}, #{item.cyp1a2Inhibition},
             #{item.cyp2c19Inhibition}, #{item.cyp2c9Inhibition}, #{item.cyp2c9Substrate},
             #{item.cyp2d6Inhibition}, #{item.cyp2d6Substrate}, #{item.cyp3a4Inhibition},
             #{item.cyp3a4Substrate}, #{item.dili}, #{item.freesolv}, #{item.hergBlockers},
             #{item.hergKarim}, #{item.hia}, #{item.ld50}, #{item.lipophilicity}, #{item.pampa},
             #{item.pgp}, #{item.ppbr}, #{item.skin}, #{item.solubility}, #{item.createdAt},
