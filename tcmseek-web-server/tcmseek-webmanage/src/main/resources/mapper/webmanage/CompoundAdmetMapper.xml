    <sql id="selectCompoundAdmetVo">
        select id, inchikey, ames, bbbp, bioavailability, caco2, carcinogens, clearance_microsome, clintox, cyp1a2_inhibition, cyp2c19_inhibition, cyp2c9_inhibition, cyp2c9_substrate, cyp2d6_inhibition, cyp2d6_substrate, cyp3a4_inhibition, cyp3a4_substrate, dili, freesolv, herg_blockers, herg_karim, hia, ld50, lipophilicity, pampa, pgp, ppbr, skin, solubility, created_at, updated_at from compound_admet
    </sql>

    <select id="selectCompoundAdmetList" parameterType="CompoundAdmet" resultMap="CompoundAdmetResult">
        <include refid="selectCompoundAdmetVo"/>
        <where>  
            <if test="inchikey != null  and inchikey != ''"> and inchikey = #{inchikey}</if>
        </where>
    </select>
    
    <select id="selectCompoundAdmetById" parameterType="Long" resultMap="CompoundAdmetResult">
        <include refid="selectCompoundAdmetVo"/>
        where id = #{id}
    </select>

