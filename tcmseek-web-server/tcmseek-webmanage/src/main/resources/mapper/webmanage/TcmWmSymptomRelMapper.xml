<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tcmseek.webmanage.mapper.TcmWmSymptomRelMapper">
    
    <resultMap type="TcmWmSymptomRel" id="TcmWmSymptomRelResult">
        <result property="id"    column="id"    />
        <result property="tcmSymptomId"    column="tcm_symptom_id"    />
        <result property="wmSymptomId"    column="wm_symptom_id"    />
        <result property="createdAt"    column="created_at"    />
    </resultMap>

    <sql id="selectTcmWmSymptomRelVo">
        select id, tcm_symptom_id, wm_symptom_id, created_at from tcm_wm_symptom_rel
    </sql>

    <select id="selectTcmWmSymptomRelList" parameterType="TcmWmSymptomRel" resultMap="TcmWmSymptomRelResult">
        <include refid="selectTcmWmSymptomRelVo"/>
        <where>  
            <if test="tcmSymptomId != null  and tcmSymptomId != ''"> and tcm_symptom_id = #{tcmSymptomId}</if>
            <if test="wmSymptomId != null  and wmSymptomId != ''"> and wm_symptom_id = #{wmSymptomId}</if>
        </where>
    </select>
    
    <select id="selectTcmWmSymptomRelById" parameterType="Long" resultMap="TcmWmSymptomRelResult">
        <include refid="selectTcmWmSymptomRelVo"/>
        where id = #{id}
    </select>

    <insert id="insertTcmWmSymptomRel" parameterType="TcmWmSymptomRel" useGeneratedKeys="true" keyProperty="id">
        insert into tcm_wm_symptom_rel
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="tcmSymptomId != null and tcmSymptomId != ''">tcm_symptom_id,</if>
            <if test="wmSymptomId != null and wmSymptomId != ''">wm_symptom_id,</if>
            <if test="createdAt != null">created_at,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="tcmSymptomId != null and tcmSymptomId != ''">#{tcmSymptomId},</if>
            <if test="wmSymptomId != null and wmSymptomId != ''">#{wmSymptomId},</if>
            <if test="createdAt != null">#{createdAt},</if>
         </trim>
    </insert>

    <update id="updateTcmWmSymptomRel" parameterType="TcmWmSymptomRel">
        update tcm_wm_symptom_rel
        <trim prefix="SET" suffixOverrides=",">
            <if test="tcmSymptomId != null and tcmSymptomId != ''">tcm_symptom_id = #{tcmSymptomId},</if>
            <if test="wmSymptomId != null and wmSymptomId != ''">wm_symptom_id = #{wmSymptomId},</if>
            <if test="createdAt != null">created_at = #{createdAt},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteTcmWmSymptomRelById" parameterType="Long">
        delete from tcm_wm_symptom_rel where id = #{id}
    </delete>

    <delete id="deleteTcmWmSymptomRelByIds" parameterType="String">
        delete from tcm_wm_symptom_rel where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>