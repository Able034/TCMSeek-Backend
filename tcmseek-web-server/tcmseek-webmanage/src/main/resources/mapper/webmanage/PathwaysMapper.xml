<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tcmseek.webmanage.mapper.PathwaysMapper">
    
    <resultMap type="Pathways" id="PathwaysResult">
        <result property="id"    column="id"    />
        <result property="pathwayId"    column="pathway_id"    />
        <result property="name"    column="name"    />
        <result property="source"    column="source"    />
        <result property="createdAt"    column="created_at"    />
        <result property="updatedAt"    column="updated_at"    />
    </resultMap>

    <sql id="selectPathwaysVo">
        select id, pathway_id, name, source, created_at, updated_at from pathways
    </sql>

    <select id="selectPathwaysList" parameterType="Pathways" resultMap="PathwaysResult">
        <include refid="selectPathwaysVo"/>
        <where>  
            <if test="pathwayId != null  and pathwayId != ''"> and pathway_id = #{pathwayId}</if>
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="source != null  and source != ''"> and source = #{source}</if>
        </where>
    </select>
    
    <select id="selectPathwaysById" parameterType="Long" resultMap="PathwaysResult">
        <include refid="selectPathwaysVo"/>
        where id = #{id}
    </select>

    <insert id="insertPathways" parameterType="Pathways" useGeneratedKeys="true" keyProperty="id">
        insert into pathways
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="pathwayId != null and pathwayId != ''">pathway_id,</if>
            <if test="name != null and name != ''">name,</if>
            <if test="source != null">source,</if>
            <if test="createdAt != null">created_at,</if>
            <if test="updatedAt != null">updated_at,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="pathwayId != null and pathwayId != ''">#{pathwayId},</if>
            <if test="name != null and name != ''">#{name},</if>
            <if test="source != null">#{source},</if>
            <if test="createdAt != null">#{createdAt},</if>
            <if test="updatedAt != null">#{updatedAt},</if>
         </trim>
    </insert>

    <update id="updatePathways" parameterType="Pathways">
        update pathways
        <trim prefix="SET" suffixOverrides=",">
            <if test="pathwayId != null and pathwayId != ''">pathway_id = #{pathwayId},</if>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="source != null">source = #{source},</if>
            <if test="createdAt != null">created_at = #{createdAt},</if>
            <if test="updatedAt != null">updated_at = #{updatedAt},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deletePathwaysById" parameterType="Long">
        delete from pathways where id = #{id}
    </delete>

    <delete id="deletePathwaysByIds" parameterType="String">
        delete from pathways where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>