<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tcmseek.webmanage.mapper.HerbSymptomRelMapper">
    
    <resultMap type="HerbSymptomRel" id="HerbSymptomRelResult">
        <result property="id"    column="id"    />
        <result property="tcmHerbId"    column="tcm_herb_id"    />
        <result property="tcmSymptomId"    column="tcm_symptom_id"    />
        <result property="createdAt"    column="created_at"    />
    </resultMap>

    <sql id="selectHerbSymptomRelVo">
        select id, tcm_herb_id, tcm_symptom_id, created_at from herb_symptom_rel
    </sql>

    <select id="selectHerbSymptomRelList" parameterType="HerbSymptomRel" resultMap="HerbSymptomRelResult">
        <include refid="selectHerbSymptomRelVo"/>
        <where>  
            <if test="tcmHerbId != null  and tcmHerbId != ''"> and tcm_herb_id = #{tcmHerbId}</if>
            <if test="tcmSymptomId != null  and tcmSymptomId != ''"> and tcm_symptom_id = #{tcmSymptomId}</if>
        </where>
    </select>
    
    <select id="selectHerbSymptomRelById" parameterType="Long" resultMap="HerbSymptomRelResult">
        <include refid="selectHerbSymptomRelVo"/>
        where id = #{id}
    </select>

    <insert id="insertHerbSymptomRel" parameterType="HerbSymptomRel" useGeneratedKeys="true" keyProperty="id">
        insert into herb_symptom_rel
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="tcmHerbId != null and tcmHerbId != ''">tcm_herb_id,</if>
            <if test="tcmSymptomId != null and tcmSymptomId != ''">tcm_symptom_id,</if>
            <if test="createdAt != null">created_at,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="tcmHerbId != null and tcmHerbId != ''">#{tcmHerbId},</if>
            <if test="tcmSymptomId != null and tcmSymptomId != ''">#{tcmSymptomId},</if>
            <if test="createdAt != null">#{createdAt},</if>
         </trim>
    </insert>

    <update id="updateHerbSymptomRel" parameterType="HerbSymptomRel">
        update herb_symptom_rel
        <trim prefix="SET" suffixOverrides=",">
            <if test="tcmHerbId != null and tcmHerbId != ''">tcm_herb_id = #{tcmHerbId},</if>
            <if test="tcmSymptomId != null and tcmSymptomId != ''">tcm_symptom_id = #{tcmSymptomId},</if>
            <if test="createdAt != null">created_at = #{createdAt},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteHerbSymptomRelById" parameterType="Long">
        delete from herb_symptom_rel where id = #{id}
    </delete>

    <delete id="deleteHerbSymptomRelByIds" parameterType="String">
        delete from herb_symptom_rel where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>