            <if test="toxicDescriptionZh != null and toxicDescriptionZh != ''">#{toxicDescriptionZh},</if>
            <if test="toxicEffectEn != null and toxicEffectEn != ''">#{toxicEffectEn},</if>
            <if test="pharmacopoeiaRecord != null and pharmacopoeiaRecord != ''">#{pharmacopoeiaRecord},</if>
            <if test="classification != null and classification != ''">#{classification},</if>
            <if test="usePart != null and usePart != ''">#{usePart},</if>
            <if test="natureTasteZh != null and natureTasteZh != ''">#{natureTasteZh},</if>
            <if test="propertyEn != null and propertyEn != ''">#{propertyEn},</if>
            <if test="meridianZh != null and meridianZh != ''">#{meridianZh},</if>
            <if test="meridianTropismEn != null and meridianTropismEn != ''">#{meridianTropismEn},</if>
            <if test="indicationsZh != null and indicationsZh != ''">#{indicationsZh},</if>
            <if test="indicationEn != null and indicationEn != ''">#{indicationEn},</if>
            <if test="createdAt != null">#{createdAt},</if>
            <if test="updatedAt != null">#{updatedAt},</if>
            <if test="classificationZh != null and classificationZh != ''">#{classificationZh},</if>
         </trim>
    </insert>

