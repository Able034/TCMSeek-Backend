    <sql id="selectCoreTcmHerbsVo">
        select id, tcm_herb_id, herb_name_zh, pinyin_name, latin_name, english_name, type, efficacy_zh, function_en, efficacy_category, toxicity_zh, toxic_en, toxic_description_zh, toxic_effect_en, pharmacopoeia_record, classification, use_part, nature_taste_zh, property_en, meridian_zh, meridian_tropism_en, indications_zh, indication_en, created_at, updated_at, classification_zh from core_tcm_herbs
    </sql>

    <select id="selectCoreTcmHerbsList" parameterType="CoreTcmHerbs" resultMap="CoreTcmHerbsResult">
        <include refid="selectCoreTcmHerbsVo"/>
        <where>  
            <if test="tcmHerbId != null  and tcmHerbId != ''"> and tcm_herb_id = #{tcmHerbId}</if>
            <if test="herbNameZh != null  and herbNameZh != ''"> and herb_name_zh like concat('%', #{herbNameZh}, '%')</if>
            <if test="pinyinName != null  and pinyinName != ''"> and pinyin_name like concat('%', #{pinyinName}, '%')</if>
            <if test="latinName != null  and latinName != ''"> and latin_name like concat('%', #{latinName}, '%')</if>
            <if test="englishName != null  and englishName != ''"> and english_name like concat('%', #{englishName}, '%')</if>
            <if test="type != null  and type != ''"> and type = #{type}</if>
            <if test="efficacyZh != null  and efficacyZh != ''"> and efficacy_zh = #{efficacyZh}</if>
            <if test="efficacyCategory != null  and efficacyCategory != ''"> and efficacy_category = #{efficacyCategory}</if>
            <if test="toxicityZh != null  and toxicityZh != ''"> and toxicity_zh = #{toxicityZh}</if>
            <if test="toxicDescriptionZh != null  and toxicDescriptionZh != ''"> and toxic_description_zh = #{toxicDescriptionZh}</if>
            <if test="pharmacopoeiaRecord != null  and pharmacopoeiaRecord != ''"> and pharmacopoeia_record = #{pharmacopoeiaRecord}</if>
            <if test="usePart != null  and usePart != ''"> and use_part = #{usePart}</if>
            <if test="natureTasteZh != null  and natureTasteZh != ''"> and nature_taste_zh = #{natureTasteZh}</if>
            <if test="meridianZh != null  and meridianZh != ''"> and meridian_zh = #{meridianZh}</if>
            <if test="indicationsZh != null  and indicationsZh != ''"> and indications_zh = #{indicationsZh}</if>
            <if test="classificationZh != null  and classificationZh != ''"> and classification_zh = #{classificationZh}</if>
        </where>
    </select>
    
    <select id="selectCoreTcmHerbsById" parameterType="Long" resultMap="CoreTcmHerbsResult">
        <include refid="selectCoreTcmHerbsVo"/>
        where id = #{id}
    </select>

    <insert id="insertCoreTcmHerbs" parameterType="CoreTcmHerbs" useGeneratedKeys="true" keyProperty="id">
        insert into core_tcm_herbs
        <trim prefix="(" suffix=")" suffixOverrides=",">
