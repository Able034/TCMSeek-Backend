            <if test="natureTasteZh != null and natureTasteZh != ''">nature_taste_zh,</if>
            <if test="propertyEn != null and propertyEn != ''">property_en,</if>
            <if test="meridianZh != null and meridianZh != ''">meridian_zh,</if>
            <if test="meridianTropismEn != null and meridianTropismEn != ''">meridian_tropism_en,</if>
            <if test="indicationsZh != null and indicationsZh != ''">indications_zh,</if>
            <if test="indicationEn != null and indicationEn != ''">indication_en,</if>
            <if test="createdAt != null">created_at,</if>
            <if test="updatedAt != null">updated_at,</if>
            <if test="classificationZh != null and classificationZh != ''">classification_zh,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="tcmHerbId != null and tcmHerbId != ''">#{tcmHerbId},</if>
            <if test="herbNameZh != null and herbNameZh != ''">#{herbNameZh},</if>
