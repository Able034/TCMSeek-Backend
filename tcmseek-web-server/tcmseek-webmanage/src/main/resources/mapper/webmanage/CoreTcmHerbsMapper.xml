            <if test="pinyinName != null and pinyinName != ''">pinyin_name,</if>
            <if test="latinName != null and latinName != ''">latin_name,</if>
            <if test="englishName != null and englishName != ''">english_name,</if>
            <if test="type != null and type != ''">type,</if>
            <if test="efficacyZh != null and efficacyZh != ''">efficacy_zh,</if>
